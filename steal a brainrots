-- ARBIX HUB RTX V11.0 (FULL ASSVEL CONTROL)

if getgenv().ARBIX_RUNNING then
    if getgenv().ARBIX_STOP then pcall(getgenv().ARBIX_STOP) end
end
getgenv().ARBIX_RUNNING = true

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer

-- CONFIG
local config = {
    deliverySpeed = 30,
    speed = 50,
    maxHeight = 15
}

local char, hrp, hum
local activeMode = nil
local connection = nil
local targetPlayer = nil

-- REFRESH
local function RefreshRefs()
    char = player.Character or player.CharacterAdded:Wait()
    hrp = char:WaitForChild("HumanoidRootPart")
    hum = char:WaitForChild("Humanoid")
end
player.CharacterAdded:Connect(RefreshRefs)
RefreshRefs()

-- STOP
getgenv().ARBIX_STOP = function()
    activeMode = nil
    targetPlayer = nil
    if connection then connection:Disconnect() connection = nil end
    if hrp then hrp.AssemblyLinearVelocity = Vector3.zero end
    if hum then
        hum.WalkSpeed = 16
        hum.JumpPower = 50
        hum.AutoRotate = true
    end
end

-- Lock اللاعب أثناء النقل
local function LockPlayer()
    if hum then
        hum.WalkSpeed = 0
        hum.JumpPower = 0
        hum.AutoRotate = false
    end
end

-- أقرب لاعب
local function GetNearestPlayer()
    local nearest, dist = nil, math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local d = (p.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
            if d < dist then
                dist = d
                nearest = p
            end
        end
    end
    return nearest
end

-- My Delivery الخاص بك
local function GetMyDelivery()
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return nil end
    for _, p in pairs(plots:GetChildren()) do
        if p:FindFirstChild("PlotSign") and p.PlotSign:FindFirstChild("YourBase") and p.PlotSign.YourBase.Enabled then
            return p:FindFirstChild("DeliveryHitbox")
        end
    end
end

-- أقرب ديلفري مجاني
local function GetNearestDelivery()
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return nil end
    local nearest, dist = nil, math.huge
    for _, p in pairs(plots:GetChildren()) do
        if p:FindFirstChild("DeliveryHitbox") then
            local isOwned = false
            if p:FindFirstChild("PlotSign") then
                local sign = p.PlotSign
                if sign:FindFirstChild("YourBase") and sign.YourBase.Enabled then
                    isOwned = true
                end
            end
            if not isOwned then
                local d = (p.DeliveryHitbox.Position - hrp.Position).Magnitude
                if d < dist then
                    dist = d
                    nearest = p.DeliveryHitbox
                end
            end
        end
    end
    return nearest
end

-- ENGINE
local function StartEngine(mode, targetProvider)
    if activeMode == mode then return end
    activeMode = mode
    LockPlayer()

    connection = RunService.Heartbeat:Connect(function()
        pcall(function()
            if not activeMode or not hrp then return end
            local target = targetProvider()
            if not target then return end
            local tPos = target.Position
            local myPos = hrp.Position
            local dir = tPos - myPos
            local dist = dir.Magnitude
            local moveDir = dir.Unit

            -- 🚀 MY DELIVERY (رفع + حركة)
            if activeMode == "MyDelivery" then
                local heightDiff = (tPos.Y + config.maxHeight) - myPos.Y
                local yVel = math.clamp(heightDiff, -5, 25)
                hrp.AssemblyLinearVelocity = Vector3.new(
                    moveDir.X * config.deliverySpeed,
                    yVel,
                    moveDir.Z * config.deliverySpeed
                )
                -- إذا قريب جدًا من الهدف نزله على الديلفري
                if dist <= 5 then
                    hrp.AssemblyLinearVelocity = Vector3.zero
                    hrp.CFrame = target.CFrame + Vector3.new(0,2,0)
                end

            -- ⚡ Nearest Delivery (أرضي فقط)
            elseif activeMode == "NearestDelivery" then
                hrp.AssemblyLinearVelocity = Vector3.new(
                    moveDir.X * config.speed,
                    0,
                    moveDir.Z * config.speed
                )

            -- 🐕 Follow Player (أرضي فقط، يتبع أقرب لاعب)
            elseif activeMode == "FollowPlayer" then
                if target then
                    local flatDir = Vector3.new(dir.X,0,dir.Z).Unit
                    hrp.AssemblyLinearVelocity = flatDir * config.speed
                end
            end
        end)
    end)
end

-- UI
local function CreateUI()
    local pg = player:WaitForChild("PlayerGui")
    if pg:FindFirstChild("ARBIX_UI") then pg.ARBIX_UI:Destroy() end
    local sg = Instance.new("ScreenGui")
    sg.Name = "ARBIX_UI"
    sg.ResetOnSpawn = false
    sg.Parent = pg

    local main = Instance.new("Frame", sg)
    main.Size = UDim2.new(0,250,0,220)
    main.Position = UDim2.new(0.5,-125,0.3,0)
    main.BackgroundColor3 = Color3.fromRGB(15,15,25)
    main.Active = true
    main.Draggable = true
    Instance.new("UICorner", main)

    local function Btn(text,pos,mode,func)
        local b = Instance.new("TextButton", main)
        b.Size = UDim2.new(0.9,0,0,45)
        b.Position = pos
        b.Text = text
        b.TextColor3 = Color3.new(1,1,1)
        b.BackgroundColor3 = Color3.fromRGB(30,30,30)
        b.Font = "GothamBold"
        b.TextSize = 14
        Instance.new("UICorner",b)
        b.MouseButton1Click:Connect(function()
            if activeMode == mode then
                getgenv().ARBIX_STOP()
            else
                func()
            end
        end)
    end

    Btn("🚀 MY DELIVERY", UDim2.new(0.05,0,0.1,0),"MyDelivery",function()
        StartEngine("MyDelivery",GetMyDelivery)
    end)
    Btn("⚡ FREE DELIVERY", UDim2.new(0.05,0,0.4,0),"NearestDelivery",function()
        StartEngine("NearestDelivery",GetNearestDelivery)
    end)
    Btn("🐕 FOLLOW PLAYER", UDim2.new(0.05,0,0.7,0),"FollowPlayer",function()
        targetPlayer = GetNearestPlayer()
        if targetPlayer then
            StartEngine("FollowPlayer",function()
                return targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart")
            end)
        end
    end)
end

CreateUI()
