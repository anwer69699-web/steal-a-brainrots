-- إنشاء الأزرار
local function AddBtn(name, y, callback)
    local B = Instance.new("TextButton", Main)
    B.Size = UDim2.new(0, 170, 0, 40)
    B.Position = UDim2.new(0, 15, 0, y)
    B.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    B.Text = name .. " : OFF"
    B.TextColor3 = Color3.new(1, 1, 1)
    B.Font = Enum.Font.GothamBold
    Instance.new("UICorner", B)
    
    local act = false
    B.MouseButton1Click:Connect(function()
        act = not act
        B.Text = name .. (act and " : ON" or " : OFF")
        B.BackgroundColor3 = act and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(25, 25, 25)
        callback(act)
    end)
end

AddBtn("AUTO BREAK", 55, function(v) Settings.Tapping = v end)
