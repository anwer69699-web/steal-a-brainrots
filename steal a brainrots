local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local WS = game:GetService("Workspace")
local UIS = game:GetService("UserInputService")
local Player = Players.LocalPlayer
local Network = RS:WaitForChild("Network")

local Settings = {
    Tapping = false,
    Teleport = false,
    Range = 250
}

--// 2. محرك الكسر القسري (Force Break Engine)
local function ForceTap(target)
    if not target then return end
    local tid = target.Name
    
    -- [A] محاكاة ريموت الضرر (8 ضربات مركزة)
    local damageRemote = Network:FindFirstChild("Breakables_PlayerDealDamage")
    if damageRemote then
        for i = 1, 8 do
            damageRemote:FireServer(tid)
        end
    end

    -- [B] إجبار التابر الداخلي (السر في استجابة السيرفر)
    task.spawn(function()
        local tapper = Network:FindFirstChild("AutoTapper_Toggle")
        if tapper then
            if tapper:IsA("RemoteFunction") then
                tapper:InvokeServer(true)
            else
                tapper:FireServer(true)
            end
        end
    end)
end

--// 3. البحث عن الهدف (Targeting)
local function GetClosest()
    local best, dist = nil, Settings.Range
    local folder = WS:FindFirstChild("__THINGS") and WS.__THINGS:FindFirstChild("Breakables")
    
    if folder then
        for _, v in pairs(folder:GetChildren()) do
            -- نبحث عن الجزء الأساسي للصندوق لضمان تسجيل الضربة
            local p = v:FindFirstChild("Main") or v:FindFirstChildWhichIsA("BasePart", true)
            if p then
                local d = (Player.Character.HumanoidRootPart.Position - p.Position).Magnitude
                if d < dist then
                    dist = d
                    best = v
                end
            end
        end
    end
    return best
end

--// 4. الحلقة الأساسية (High-Speed Loop)
task.spawn(function()
    while task.wait(0.05) do
        if Settings.Tapping then
            local target = GetClosest()
            if target then
                -- تفعيل الكسر
                ForceTap(target)
                
                -- تفعيل التليبورت إذا كان مختاراً
                if Settings.Teleport and Player.Character:FindFirstChild("HumanoidRootPart") then
                    local part = target:FindFirstChild("Main") or target:FindFirstChildWhichIsA("BasePart", true)
                    if part then
                        Player.Character.HumanoidRootPart.CFrame = part.CFrame * CFrame.new(0, 5, 0)
                    end
                end
            end
        end
    end
end)

