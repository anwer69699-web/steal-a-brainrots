local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer
local set_clipboard = setclipboard or toclipboard or print

-- إعدادات الحركة
local CONFIG = {
    Base = { H_Speed = 29.2, V_Speed = 50, StopDist = 23, MaxH = 20, DiveDist = 30 }, 
    Order = { H_Speed = 48, V_Speed = 48, StopDist = 15, MaxH = 20, DiveDist = 50 }, 
    Chase = { H_Speed = 48, V_Speed = 48, StopDist = 0, MaxH = 999, DiveDist = 30 }
}

local activeMode = nil
local btns = {}
local char, hrp, hum
local currentSession = 0

-- تحديث مراجع الشخصية
local function UpdateCharacterRefs()
    char = player.Character or player.CharacterAdded:Wait()
    hrp = char:WaitForChild("HumanoidRootPart", 10)
    hum = char:WaitForChild("Humanoid", 10)
    return (hrp and hum)
end

-- العثور على أقرب لاعب
local function GetClosestPlayer()
    local closest, dist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local d = (p.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
            if d < dist then
                dist = d
                closest = p.Character.HumanoidRootPart
            end
        end
    end
    return closest
end

-- العثور على أقرب دلفري بوكس
local function GetClosestDeliveryBox()
    local closest, dist = nil, math.huge
    local plots = workspace:FindFirstChild("Plots")
    if plots then
        for _, p in ipairs(plots:GetChildren()) do
            local sign = p:FindFirstChild("PlotSign")
            if sign and sign:FindFirstChild("DeliveryHitbox") then
                local d = (sign.DeliveryHitbox.Position - hrp.Position).Magnitude
                if d < dist then
                    dist = d
                    closest = sign.DeliveryHitbox
                end
            end
        end
    end
    return closest
end

getgenv().LEVIX_STOP = function()
    currentSession += 1
    activeMode = nil
    if hum and hum.Parent then hum.WalkSpeed, hum.JumpPower = 16, 50 end
    if hrp and hrp.Parent then hrp.AssemblyLinearVelocity = Vector3.zero end
    for _, b in pairs(btns) do
        local s = b:FindFirstChildOfClass("UIStroke")
        if s then s.Color = Color3.fromRGB(45, 45, 55) end
    end
end

local function RunEngine(mode)
    if activeMode == mode then getgenv().LEVIX_STOP() return end
    getgenv().LEVIX_STOP()
    
    currentSession += 1
    local mySession = currentSession
    activeMode = mode
    UpdateCharacterRefs()
    
    if hum then hum.WalkSpeed, hum.JumpPower = 0, 0 end
    if btns[mode] then btns[mode].UIStroke.Color = Color3.fromRGB(0, 255, 200) end

    task.spawn(function()
        local startPos = hrp.Position
        local cachedTarget = nil

        while activeMode == mode and mySession == currentSession do
            RunService.Stepped:Wait()
            if not UpdateCharacterRefs() or hum.Health <= 0 then continue end

            local cfg = (mode == "Mine") and CONFIG.Base or (mode == "Order" and CONFIG.Order or CONFIG.Chase)
            local targetPart = nil

            -- تحديد الهدف
            if mode == "Chase" then
                targetPart = GetClosestPlayer()
            else
                if not cachedTarget or not cachedTarget.Parent then
                    local plots = workspace:FindFirstChild("Plots")
                    if plots then
                        for _, p in ipairs(plots:GetChildren()) do
                            local sign = p:FindFirstChild("PlotSign")
                            if mode == "Order" and sign and (not sign:FindFirstChild("YourBase") or not sign.YourBase.Enabled) then
                                targetPart = p:FindFirstChild("DeliveryHitbox")
                                if targetPart then cachedTarget = targetPart break end
                            elseif mode == "Mine" and sign and sign:FindFirstChild("YourBase") and sign.YourBase.Enabled then
                                targetPart = p:FindFirstChild("DeliveryHitbox")
                                if targetPart then cachedTarget = targetPart break end
                            end
                        end
                    end
                else
                    targetPart = cachedTarget
                end
            end

            if not targetPart then task.wait(0.2) continue end
            
            local targetPos = targetPart.Position
            local currentPos = hrp.Position
            local flatDist = Vector2.new(targetPos.X - currentPos.X, targetPos.Z - currentPos.Z).Magnitude

            -- التوقف النهائي
            if mode ~= "Chase" and (targetPos - currentPos).Magnitude < cfg.StopDist then
                getgenv().LEVIX_STOP()
                break
            end

            local hVel = Vector3.zero
            local vVel = 0
            local moveDir = (Vector3.new(targetPos.X, 0, targetPos.Z) - Vector3.new(currentPos.X, 0, currentPos.Z)).Unit

            -- منطق الحركة المطور (قوس هجومي مسافاتي)
            if mode == "Chase" then
                local verticalDist = targetPos.Y - currentPos.Y
                -- إذا كان اللاعب الآخر على ارتفاع أعلى، ارفع الشخصية لتكون في مستوى الهدف
                if verticalDist > 2 then
                    hVel = moveDir * cfg.H_Speed
                    vVel = math.clamp(verticalDist * 10, -cfg.V_Speed, cfg.V_Speed)  -- استخدام الرفع هنا لتسريع الوصول
                else
                    -- حركة أفقية فقط إذا كان اللاعب على الأرض
                    hVel = moveDir * cfg.H_Speed
                    vVel = 0  -- لا حاجة للرفع إذا كان الهدف على الأرض
                end
            else
                if flatDist > cfg.DiveDist then
                    -- التحرك للأمام باستخدام الرفع
                    hVel = moveDir * cfg.H_Speed
                    local heightDiff = (startPos.Y + cfg.MaxH) - currentPos.Y
                    vVel = math.clamp(heightDiff * 10, -cfg.V_Speed, cfg.V_Speed)
                else
                    -- الانقضاض على الهدف بشكل أسرع
                    hVel = moveDir * cfg.H_Speed
                    local verticalDir = (targetPos.Y - currentPos.Y)
                    vVel = math.clamp(verticalDir * 15, -cfg.V_Speed, cfg.V_Speed)
                end
            end

            hrp.AssemblyLinearVelocity = Vector3.new(hVel.X, vVel, hVel.Z)
            hrp.AssemblyAngularVelocity = Vector3.zero
        end
    end)
end

-- UI
local function CreateUI()
    for _, v in pairs(player.PlayerGui:GetChildren()) do if v.Name == "Levix_Hub" then v:Destroy() end end
    local sg = Instance.new("ScreenGui", player.PlayerGui)
    sg.Name = "Levix_Hub"
    sg.ResetOnSpawn = false 

    local main = Instance.new("Frame", sg)
    main.Size, main.Position = UDim2.new(0, 160, 0, 240), UDim2.new(0.5, -80, 0.4, 0)
    main.BackgroundColor3 = Color3.fromRGB(10, 10, 12)
    main.Active, main.Draggable = true, true
    Instance.new("UICorner", main)
    Instance.new("UIStroke", main).Color = Color3.fromRGB(0, 255, 200)

    local title = Instance.new("TextLabel", main)
    title.Size, title.Position = UDim2.new(1, 0, 0, 35), UDim2.new(0, 0, 0, 0)
    title.Text, title.TextColor3, title.Font, title.TextSize = "LEVIX HUB X Ugly?", Color3.new(1,1,1), "GothamBold", 10
    title.BackgroundTransparency = 1

    local function MakeBtn(txt, y, mode)
        local b = Instance.new("TextButton", main)
        b.Size, b.Position = UDim2.new(0.85, 0, 0, 30), UDim2.new(0.075, 0, 0, y)
        b.Text, b.BackgroundColor3 = txt, Color3.fromRGB(18, 18, 22)
        b.TextColor3, b.Font, b.TextSize = Color3.fromRGB(255, 255, 255), "GothamBold", 8
        Instance.new("UICorner", b)
        local bs = Instance.new("UIStroke", b) bs.Color = Color3.fromRGB(45, 45, 55)
        btns[mode] = b
        b.MouseButton1Click:Connect(function() RunEngine(mode) end)
    end

    MakeBtn("منزلك", 45, "Mine")
    MakeBtn("(dual) Go to steal", 85, "Order")
    MakeBtn("Bat", 125, "Chase")

    local function Social(txt, val, y)
        local b = Instance.new("TextButton", main)
        b.Size, b.Position = UDim2.new(0.85, 0, 0, 25), UDim2.new(0.075, 0, 0, y)
        b.Text, b.TextColor3, b.BackgroundColor3 = txt, Color3.fromRGB(0, 255, 200), Color3.fromRGB(25, 25, 30)
        b.Font, b.TextSize = "GothamBold", 7
        Instance.new("UICorner", b)
        b.MouseButton1Click:Connect(function() set_clipboard(val) b.Text = "COPIED!" task.wait(1) b.Text = txt end)
    end

    Social("📱 TikTok: Levix_rl", "Levix_rl", 170)
    Social("💬 Discord Server", "https://discord.gg/yhVCKMMP", 200)
end

CreateUI()
