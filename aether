local KeySystem = {
    IsValid = false,
    IsOwner = false,
    IsFree = false,
    VerifiedUsers = {},
}

function KeySystem:FetchKeys()
    local success, response = pcall(function()
        return game:HttpGet(self.Config.KeysURL)
    end)

    if not success or not response then
        warn("[Aether] Failed to fetch keys")
        return {}
    end

    local keysTable = {}
    for line in string.gmatch(response, "[^\r\n]+") do
        local key, userid = string.match(line, "{(.-)},{(.-)}")
        if key and userid then
            key = string.upper(string.gsub(key, "%s+", ""))
            userid = string.gsub(userid, "%s+", "")
            keysTable[key] = userid
        end
    end
    return keysTable
end

function KeySystem:IsExpired(data)
    return data.expire and os.time() > data.expire
end

function KeySystem:VerifyKey(inputKey)
    inputKey = inputKey and string.upper(string.match(inputKey, "^%s*(.-)%s*$")) or ""

    if #inputKey == 0 then return false, "Empty key!", "normal" end
    if #inputKey > self.Config.MaxKeyLength then return false, "Max 24 chars!", "normal" end

    local userId = tostring(Player.UserId)
    local current = self.VerifiedUsers[userId]
    if current and not self:IsExpired(current) then
        return true, "Already activated!", self.IsOwner and "owner" or "normal"
    end

    -- Owner Key
    if inputKey == string.upper(self.Config.OwnerKey) then
        if userId ~= tostring(self.Config.OwnerUserId) then
            return false, "Owner only!", "normal"
        end
        self.IsOwner = true
        self.IsValid = true
        self.VerifiedUsers[userId] = {key = inputKey, expire = math.huge}
        return true, "Owner activated!", "owner"
    end

    -- Free Key
    if self.Config.FreeKeyEnabled and inputKey == string.upper(self.Config.FreeKey) then
        self.IsValid = true
        self.IsFree = true
        self.VerifiedUsers[userId] = {key = inputKey, expire = math.huge}
        return true, "Free key used!", "free"
    end

    -- Normal Keys
    local keys = self:FetchKeys()
    local validUserId = keys[inputKey]
    if not validUserId then return false, "Invalid key!", "normal" end
    if tostring(validUserId) ~= userId then return false, "Not your key!", "normal" end

    self.IsValid = true
    self.VerifiedUsers[userId] = {key = inputKey, expire = math.huge}
    return true, "Key activated!", "normal"
end

function KeySystem:IsUserVerified()
    local data = self.VerifiedUsers[tostring(Player.UserId)]
    if not data then return false end
    if self:IsExpired(data) then
        self.VerifiedUsers[tostring(Player.UserId)] = nil
        return false
    end
    return true
end

