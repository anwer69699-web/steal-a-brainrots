            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 14)
            createGlowGradient(btn, SpeedSettings.ButtonBorder, 1.8)
            createTextGradient(btn, SpeedSettings.TextEffect)

            local dragState = {
                dragging = false,
                startPos = nil,
                btnPos = nil,
                moved = false,
                inputObj = nil
            }

            btn.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
                    dragState.dragging = true
                    dragState.moved = false
                    dragState.startPos = {x = inp.Position.X, y = inp.Position.Y}
                    dragState.btnPos = btn.Position
                    dragState.inputObj = inp
                end
            end)

            UserInputService.InputChanged:Connect(function(inp)
                if dragState.dragging and dragState.startPos and dragState.btnPos then
                    if inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch then
                        local dx = math.abs(inp.Position.X - dragState.startPos.x)
                        local dy = math.abs(inp.Position.Y - dragState.startPos.y)
                        if dx > 6 or dy > 6 then
                            dragState.moved = true
                        end
                        btn.Position = dragState.btnPos + UDim2.new(0, inp.Position.X - dragState.startPos.x, 0, inp.Position.Y - dragState.startPos.y)
                    end
                end
            end)

            UserInputService.InputEnded:Connect(function(inp)
                if dragState.dragging then
                    if (inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch) then
                        if not dragState.moved then
                            callback()
                        end
                        dragState.dragging = false
                        dragState.startPos = nil
                        dragState.btnPos = nil
                        dragState.inputObj = nil
                    end
                end
            end)

            return btn
        end

