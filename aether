end

local function resetVel()
    pcall(function()
        local c = Player.Character
        if not c then return end
        local h = c:FindFirstChild("HumanoidRootPart")
        local hum = c:FindFirstChildOfClass("Humanoid")
        if h then h.AssemblyLinearVelocity = Vector3.new(0,0,0) end
        if hum then hum:Move(Vector3.zero,false) end
    end)
end

local function stopOldMovement(mode)
    if mode == "Lock" then
        if Connections.lock then Connections.lock:Disconnect(); Connections.lock = nil end
        if lockBAV then lockBAV:Destroy(); lockBAV = nil end
        Enabled.Lock = false
        if VisualSetters.Lock then VisualSetters.Lock(false, true) end
        if ScreenBtnRefs.Lock then ScreenBtnRefs.Lock(false) end
    elseif mode == "AutoLeft" then
        autoLeftId = autoLeftId + 1
        if autoLeftThread then pcall(function() task.cancel(autoLeftThread) end) autoLeftThread = nil end
        Enabled.AutoLeft = false
        if VisualSetters.AutoLeft then VisualSetters.AutoLeft(false, true) end
        if ScreenBtnRefs.AutoLeft then ScreenBtnRefs.AutoLeft(false) end
    elseif mode == "AutoRight" then
        autoRightId = autoRightId + 1
        if autoRightThread then pcall(function() task.cancel(autoRightThread) end) autoRightThread = nil end
        Enabled.AutoRight = false
        if VisualSetters.AutoRight then VisualSetters.AutoRight(false, true) end
        if ScreenBtnRefs.AutoRight then ScreenBtnRefs.AutoRight(false) end
    end
end

local function forceStopMovement()
    stopOldMovement(CurrentMode)
    CurrentMode = "None"
    resetVel()
end

local function setMovementState(n, sf)
    if CurrentMode == n then return end
    if CurrentMode ~= "None" then stopOldMovement(CurrentMode) end
    CurrentMode = "None"; resetVel()
    if n == "None" then return end
    CurrentMode = n; sf()
end

-- ===== ANTI RAGDOLL =====
local function startAntiRagdoll()
    if #AntiRagdollConns > 0 then return end
    pcall(function()
        local char = Player.Character or Player.CharacterAdded:Wait()
        local humanoid = char:WaitForChild("Humanoid")
        local root = char:WaitForChild("HumanoidRootPart")
        local cam = workspace.CurrentCamera
        local animator = humanoid:WaitForChild("Animator")
        local lastV = Vector3.new(0, 0, 0)

        local function isRag()
            local s = humanoid:GetState()
            return s == Enum.HumanoidStateType.Physics or s == Enum.HumanoidStateType.Ragdoll or s == Enum.HumanoidStateType.FallingDown or s == Enum.HumanoidStateType.GettingUp
        end

        local function clean()
            for _,o in pairs(char:GetDescendants()) do
                if o:IsA("BallSocketConstraint") or o:IsA("NoCollisionConstraint") or o:IsA("HingeConstraint") or (o:IsA("Attachment") and (o.Name == "A" or o.Name == "B")) then
                    o:Destroy()
                elseif o:IsA("BodyVelocity") or o:IsA("BodyPosition") or o:IsA("BodyGyro") then
                    o:Destroy()
                elseif o:IsA("Motor6D") then
                    o.Enabled = true
                end
            end
            for _,t in pairs(animator:GetPlayingAnimationTracks()) do
                local a = t.Animation and t.Animation.Name:lower() or ""
                if a:find("rag") or a:find("fall") or a:find("hurt") then t:Stop(0) end
            end
        end

        local function reEn()
            pcall(function() require(Player:WaitForChild("PlayerScripts"):WaitForChild("PlayerModule")):GetControls():Enable() end)
        end

        table.insert(AntiRagdollConns, humanoid.StateChanged:Connect(function()
            if isRag() then humanoid:ChangeState(Enum.HumanoidStateType.Running); clean(); cam.CameraSubject = humanoid; reEn() end
        end))
        table.insert(AntiRagdollConns, RunService.Heartbeat:Connect(function()
            if isRag() then
                clean()
                local v = root.AssemblyLinearVelocity
                if (v - lastV).Magnitude > 40 and v.Magnitude > 25 then
                    root.AssemblyLinearVelocity = v.Unit * math.min(v.Magnitude, 15)
                end
                lastV = v
            end
        end))
        table.insert(AntiRagdollConns, char.DescendantAdded:Connect(function()
            if isRag() then clean() end
        end))
        table.insert(AntiRagdollConns, Player.CharacterAdded:Connect(function(n)
            char=n; humanoid=n:WaitForChild("Humanoid"); root=n:WaitForChild("HumanoidRootPart"); animator=humanoid:WaitForChild("Animator"); lastV=Vector3.new(0, 0, 0)
            reEn(); clean()
        end))

        reEn(); clean()
    end)
end

local function stopAntiRagdoll()
    for _,c in pairs(AntiRagdollConns) do pcall(function() c:Disconnect() end) end
    AntiRagdollConns = {}
end

