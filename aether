    local function startAntiRag()
        if #arConns > 0 then return end
        pcall(function()
            local ch  = Player.Character or Player.CharacterAdded:Wait()
            local hm  = ch:WaitForChild("Humanoid")
            local hrp = ch:WaitForChild("HumanoidRootPart")
            local cam = workspace.CurrentCamera
            local ani = hm:WaitForChild("Animator")
            local lv  = Vector3.zero

            local function isRag()
                local s = hm:GetState()
                return s == Enum.HumanoidStateType.Physics
                    or s == Enum.HumanoidStateType.Ragdoll
                    or s == Enum.HumanoidStateType.FallingDown
                    or s == Enum.HumanoidStateType.GettingUp
            end
            local function clean()
                for _, o in pairs(ch:GetDescendants()) do
                    if o:IsA("BallSocketConstraint") or o:IsA("NoCollisionConstraint")
                    or o:IsA("HingeConstraint") or o:IsA("BodyVelocity")
                    or o:IsA("BodyPosition")    or o:IsA("BodyGyro") then
                        pcall(function() o:Destroy() end)
                    elseif o:IsA("Motor6D") then
                        o.Enabled = true
                    end
                end
                for _, t in pairs(ani:GetPlayingAnimationTracks()) do
                    local n = t.Animation and t.Animation.Name:lower() or ""
                    if n:find("rag") or n:find("fall") or n:find("hurt") then t:Stop(0) end
                end
            end
            local function reEnable()
                pcall(function()
                    require(Player:WaitForChild("PlayerScripts")
                        :WaitForChild("PlayerModule")):GetControls():Enable()
                end)
            end

            table.insert(arConns, hm.StateChanged:Connect(function()
                if isRag() then
                    hm:ChangeState(Enum.HumanoidStateType.Running)
                    clean(); cam.CameraSubject = hm; reEnable()
                end
            end))
            table.insert(arConns, RunService.Heartbeat:Connect(function()
                if isRag() then
                    clean()
                    local vel = hrp.AssemblyLinearVelocity
                    if (vel - lv).Magnitude > 40 and vel.Magnitude > 25 then
                        hrp.AssemblyLinearVelocity = vel.Unit * math.min(vel.Magnitude, 15)
                    end
                    lv = vel
                end
            end))
            table.insert(arConns, ch.DescendantAdded:Connect(function()
                if isRag() then clean() end
            end))
            table.insert(arConns, Player.CharacterAdded:Connect(function(nc)
                ch = nc; hm = nc:WaitForChild("Humanoid")
                hrp = nc:WaitForChild("HumanoidRootPart")
                ani = hm:WaitForChild("Animator")
                lv = Vector3.zero; reEnable(); clean()
            end))
            reEnable(); clean()
        end)
    end
    local function stopAntiRag()
        for _, c in pairs(arConns) do pcall(function() c:Disconnect() end) end
        arConns = {}
    end

