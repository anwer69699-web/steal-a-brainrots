        local pct = (Values[vK] - mn) / (mx - mn); fill.Size = UDim2.new(pct, 0, 1, 0)
        local dg = false
        local sBt = Instance.new("TextButton", sBg); sBt.Size = UDim2.new(1, 0, 4, 0); sBt.Position = UDim2.new(0, 0, -1.5, 0); sBt.BackgroundTransparency = 1; sBt.Text = ""; sBt.ZIndex = 59
        local function ud(rel) rel = math.clamp(rel, 0, 1); fill.Size = UDim2.new(rel, 0, 1, 0); local v = math.floor(mn + (mx - mn) * rel); vL.Text = tostring(v); Values[vK] = v end
        SliderSetters[vK] = function(v) v = math.clamp(v, mn, mx); local r = (v - mn) / (mx - mn); fill.Size = UDim2.new(r, 0, 1, 0); vL.Text = tostring(v); Values[vK] = v end
        sBt.MouseButton1Down:Connect(function() dg = true end)
        sBt.InputBegan:Connect(function(inp) if inp.UserInputType == Enum.UserInputType.Touch then dg = true end end)
        UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dg = false end end)
        UserInputService.InputChanged:Connect(function(i) if dg and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then local as = sBg.AbsoluteSize; if as and as.X > 0 then ud((i.Position.X - sBg.AbsolutePosition.X) / as.X) end end end)
    end

    -- Build Settings Content
    local sy = 4
    createSetSlider(sy, "Boost Speed", 14, 90, "BoostSpeed"); sy = sy + 32
    createSetSlider(sy, "Steal Speed", 10, 50, "StealSpeed"); sy = sy + 32
    createSetSlider(sy, "Lock Speed", 10, 80, "LockSpeed"); sy = sy + 32
    createSetToggle(sy, "Anti Ragdoll", "AntiRagdoll", function(s) if s then startAntiRagdoll() else stopAntiRagdoll() end); sy = sy + 26
    createSetToggle(sy, "Fast Steal", "FastSteal", function(s) if s then startFastSteal() else stopFastSteal() end); sy = sy + 26
    createSetToggle(sy, "Galaxy Sky", "GalaxySky", function(s) if s then pcall(function() Lighting.Ambient = Color3.fromRGB(40, 80, 140); Lighting.Brightness = 2.5; Lighting.ClockTime = 6; Lighting.FogEnd = 100000 end) else pcall(function() Lighting.Ambient = Color3.fromRGB(127,127,127); Lighting.Brightness = 2; Lighting.ClockTime = 14 end) end); sy = sy + 26

    -- Show Settings
    connectTouch(setBtn, function() settingsFrame.Visible = not settingsFrame.Visible end)

    -- Auto Start
    task.spawn(function() task.wait(1); Enabled.SpeedBoost = true; startSpeedBoost(); if VisualSetters.SpeedBoost then VisualSetters.SpeedBoost(true, true) end; Enabled.AntiRagdoll = true; startAntiRagdoll(); if VisualSetters.AntiRagdoll then VisualSetters.AntiRagdoll(true, true) end end)
    notify("AETHER V3", "UI Loaded Successfully!", "success", 3)
end
