    end
    local function stopFastSteal() Connections.fastSteal = false end

    -- Waypoints
    local LWP = {{Vector3.new(-474.78, -7.06, 91.00), 1}, {Vector3.new(-487.94, -5.09, 99.13), 1}, {Vector3.new(-475.72, -7.05, 97.02), 2}, {Vector3.new(-474.42, -7.06, 24.68), 2}, {Vector3.new(-486.29, -4.99, 22.06), 2}}
    local RWP = {{Vector3.new(-474.03, -7.06, 26.82), 1}, {Vector3.new(-487.79, -5.04, 20.63), 1}, {Vector3.new(-475.02, -7.07, 23.55), 2}, {Vector3.new(-473.90, -7.07, 100.04), 2}, {Vector3.new(-485.13, -5.09, 104.42), 2}}
    
    local function runWP(wps, idKey, enKey)
        local myId = taskIds[idKey] + 1
        taskIds[idKey] = myId
        task.spawn(function()
            for _, wpd in ipairs(wps) do
                local wp, mode = wpd[1], wpd[2]
                while task.wait() do
                    if taskIds[idKey] ~= myId then break end
                    local c = Player.Character; if not c then break end; local h = c:FindFirstChild("HumanoidRootPart"); if not h then break end
                    local dXZ = Vector3.new(wp.X - h.Position.X, 0, wp.Z - h.Position.Z)
                    if dXZ.Magnitude < 1 then h.CFrame = CFrame.new(wp.X, h.Position.Y, wp.Z); break end
                    local md = dXZ.Unit; local hm = c:FindFirstChildOfClass("Humanoid"); if hm then hm:Move(md, false) end
                    h.AssemblyLinearVelocity = Vector3.new(md.X * (mode == 1 and Values.BoostSpeed or Values.StealSpeed), h.AssemblyLinearVelocity.Y, md.Z * (mode == 1 and Values.BoostSpeed or Values.StealSpeed))
                end
            end
            if taskIds[idKey] == myId then resetVel(); CurrentMode = "None"; Enabled[enKey] = false; if VisualSetters[enKey] then VisualSetters[enKey](false, true) end end
        end)
    end
    
