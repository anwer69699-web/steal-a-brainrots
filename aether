    local function stopAR() taskIds.arId = taskIds.arId + 1; if CurrentMode == "AutoRight" then CurrentMode = "None" end; resetVel() end

    -- LOCK TARGET
    local function findNearestPlayer()
        local c = Player.Character; if not c then return nil end; local h = c:FindFirstChild("HumanoidRootPart"); if not h then return nil end
        local best, bd = nil, math.huge
        for _, p in Players:GetPlayers() do if p ~= Player and p.Character then local eh = p.Character:FindFirstChild("HumanoidRootPart"); local hm = p.Character:FindFirstChildOfClass("Humanoid"); if eh and hm and hm.Health > 0 then local d = (eh.Position - h.Position).Magnitude; if d < bd then bd = d; best = eh end end end end
        return best
    end

    local function startLock()
        if Connections.lock then return end
        Connections.lock = RunService.Heartbeat:Connect(function()
            if not Enabled.Lock or CurrentMode ~= "Lock" then return end
            pcall(function()
                local c = Player.Character; if not c then return end; local h = c:FindFirstChild("HumanoidRootPart"); local hm = c:FindFirstChildOfClass("Humanoid"); if not h or not hm then return end
                local tg = findNearestPlayer(); if not tg then resetVel(); return end
                local tt = tg.Position - h.Position; local flat = Vector3.new(tt.X, 0, tt.Z); local dist = flat.Magnitude
                local mv = Vector3.zero
                if dist > 4 then local dir = flat.Unit; mv = dir * Values.LockSpeed; hm:Move(dir, false) else hm:Move(Vector3.zero, false) end
