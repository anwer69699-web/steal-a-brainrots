    local function isMB(pn)
        local pf = workspace:FindFirstChild("Plots")
        if not pf then return false end
        local p = pf:FindFirstChild(pn)
        if not p then return false end
        local s = p:FindFirstChild("PlotSign")
        if not s then return false end
        local yb = s:FindFirstChild("YourBase")
        return yb and yb:IsA("BillboardGui") and yb.Enabled == true
    end

    local function sSP(pl)
        if not pl or not pl:IsA("Model") then return end
        if isMB(pl.Name) then return end
        local pd = pl:FindFirstChild("AnimalPodiums")
        if not pd then return end
        for _, po in ipairs(pd:GetChildren()) do
            if po:IsA("Model") and po:FindFirstChild("Base") then
                local pv = nil
                pcall(function() pv = po:GetPivot().Position end)
                if pv then
                    table.insert(aAC, {plot = pl.Name, slot = po.Name, worldPosition = pv, uid = pl.Name .. "_" .. po.Name})
                end
            end
        end
    end

    local function initScan()
        if ISD.ScannerRunning then return end
        ISD.ScannerRunning = true
        task.spawn(function()
            task.wait(2)
            local pf = workspace:FindFirstChild("Plots")
            if not pf then pcall(function() pf = workspace:WaitForChild("Plots", 10) end) end
            if not pf then ISD.ScannerRunning = false; return end
            for _, pl in ipairs(pf:GetChildren()) do
                if pl:IsA("Model") then sSP(pl) end
            end
            task.spawn(function()
                while ISD.ScannerRunning do
                    task.wait(5)
                    if not ISD.ScannerRunning then break end
                    aAC = {}
                    if pf and pf.Parent then
                        for _, pl in ipairs(pf:GetChildren()) do
                            if pl:IsA("Model") then sSP(pl) end
                        end
                    end
                end
            end)
        end)
    end

    local function fPPFA(ad)
        if not ad then return nil end
        local cp = PMC[ad.uid]
        if cp and cp.Parent then return cp end
        local pf = workspace:FindFirstChild("Plots")
        if not pf then return nil end
        local pl = pf:FindFirstChild(ad.plot)
        if not pl then return nil end
        local pd = pl:FindFirstChild("AnimalPodiums")
        if not pd then return nil end
        local po = pd:FindFirstChild(ad.slot)
        if not po then return nil end
        local b = po:FindFirstChild("Base")
        if not b then return nil end
        local sp = b:FindFirstChild("Spawn")
        if not sp then return nil end
        local at = sp:FindFirstChild("PromptAttachment")
        if not at then return nil end
        for _, p in ipairs(at:GetChildren()) do
            if p:IsA("ProximityPrompt") then PMC[ad.uid] = p; return p end
        end
        return nil
    end

    local function fN(tp)
        local n = nil
        local md = math.huge
        for _, ad in ipairs(aAC) do
            if not ad.worldPosition then continue end
            local pm = PMC[ad.uid]
            if not pm or not pm.Parent then pm = fPPFA(ad) end
            if not pm or not pm.Enabled then continue end
            local mx = pm.MaxActivationDistance
            if mx and mx > 0 then mx = mx + 2 else mx = ISD.Radius end
            local d = (tp - ad.worldPosition).Magnitude
            if d < md and d <= mx then md = d; n = ad end
        end
        return n
    end

    local function bSC(pm)
        if ISC[pm] then return end
        local d = {holdCallbacks = {}, triggerCallbacks = {}, ready = true}
        local o1, c1 = pcall(function() return getconnections(pm.PromptButtonHoldBegan) end)
        if o1 and type(c1) == "table" then
            for _, cn in ipairs(c1) do
                if type(cn.Function) == "function" then table.insert(d.holdCallbacks, cn.Function) end
            end
        end
        local o2, c2 = pcall(function() return getconnections(pm.Triggered) end)
        if o2 and type(c2) == "table" then
            for _, cn in ipairs(c2) do
                if type(cn.Function) == "function" then table.insert(d.triggerCallbacks, cn.Function) end
            end
        end
        if (#d.holdCallbacks > 0) or (#d.triggerCallbacks > 0) then ISC[pm] = d end
    end

    local function eISA(pm)
        local d = ISC[pm]
        if not d or not d.ready then return false end
        if tick() - lST < 0.05 then return false end
        d.ready = false
        ISf = true
        lST = tick()
        task.spawn(function()
            if #d.holdCallbacks > 0 then
                for _, fn in ipairs(d.holdCallbacks) do pcall(fn) end
            end
            if #d.triggerCallbacks > 0 then
                for _, fn in ipairs(d.triggerCallbacks) do pcall(fn) end
            end
            task.wait(0.04)
            d.ready = true
            ISf = false
        end)
        return true
    end

    local function aS(pm)
        if not pm or not pm.Parent then return false end
        bSC(pm)
        if not ISC[pm] then return false end
        return eISA(pm)
    end

    local function aSL()
        if ISD.Connection then ISD.Connection:Disconnect() end
        ISD.Connection = RunService.Heartbeat:Connect(function()
            if not Enabled.InstaSteal or ISf then return end
            local hrp = gHRP()
            if not hrp then return end
            local ta = fN(hrp.Position)
            if not ta then return end
            local pm = PMC[ta.uid]
            if not pm or not pm.Parent then pm = fPPFA(ta) end
            if pm and pm.Enabled then aS(pm) end
        end)
    end

    local function startIS()
        if ISD.Connection then return end
        initScan()
        aSL()
    end

    local function stopIS()
        if ISD.Connection then ISD.Connection:Disconnect(); ISD.Connection = nil end
        ISD.ScannerRunning = false
        aAC = {}
        PMC = {}
        ISC = {}
