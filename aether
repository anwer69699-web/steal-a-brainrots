local function isMyBase(pN)
    local p = workspace:FindFirstChild("Plots")
    if not p then return false end
    p = p:FindFirstChild(pN)
    if not p then return false end
    local s = p:FindFirstChild("PlotSign")
    if not s then return false end
    local y = s:FindFirstChild("YourBase")
    return y and y:IsA("BillboardGui") and y.Enabled
end

local function scanPlot(plot)
    if not plot or not plot:IsA("Model") or isMyBase(plot.Name) then return end
    local p = plot:FindFirstChild("AnimalPodiums")
    if not p then return end
    for _, d in ipairs(p:GetChildren()) do
        if d:IsA("Model") and d:FindFirstChild("Base") then
            local pv;
            pcall(function() pv = d:GetPivot().Position end)
            if pv then
                table.insert(aAC, {plot = plot.Name, slot = d.Name, wp = pv, uid = plot.Name .. "_" .. d.Name})
            end
        end
    end
end

local function initScan()
    if ISD.Scanning then return end
    ISD.Scanning = true
    task.spawn(function()
        task.wait(2)
        local pF = workspace:FindFirstChild("Plots")
        if not pF then pcall(function() pF = workspace:WaitForChild("Plots", 10) end) end
        if not pF then ISD.Scanning = false; return end
        for _, p in ipairs(pF:GetChildren()) do
            if p:IsA("Model") then scanPlot(p) end
        end
        task.spawn(function()
            while ISD.Scanning do
                task.wait(5)
                if not ISD.Scanning then break end
                aAC = {}
                if pF and pF.Parent then
                    for _, p in ipairs(pF:GetChildren()) do
                        if p:IsA("Model") then scanPlot(p) end
                    end
                end
            end
        end)
    end)
end

local function findPrompt(aD)
    local cachedPrompt = PMC[aD.uid]
    if cachedPrompt and cachedPrompt.Parent then return cachedPrompt end
    local pF = workspace:FindFirstChild("Plots")
    if not pF then return nil end
    local p = pF:FindFirstChild(aD.plot)
    if not p then return nil end
    local po = p:FindFirstChild("AnimalPodiums")
    if not po then return nil end
    local pd = po:FindFirstChild(aD.slot)
    if not pd then return nil end
    local b = pd:FindFirstChild("Base")
    if not b then return nil end
    local s = b:FindFirstChild("Spawn")
    if not s then return nil end
    local a = s:FindFirstChild("PromptAttachment")
    if not a then return nil end
    for _, pr in ipairs(a:GetChildren()) do
        if pr:IsA("ProximityPrompt") then
            PMC[aD.uid] = pr
            return pr
        end
    end
    return nil
end

local function findNearest(tP)
    local nearest, minDist = nil, math.huge
    for _, aD in ipairs(aAC) do
        if not aD.wp then continue end
        local prompt = PMC[aD.uid]
        if not prompt or not prompt.Parent then prompt = findPrompt(aD) end
        if not prompt or not prompt.Enabled then continue end
        local maxDist = prompt.MaxActivationDistance
        if maxDist and maxDist > 0 then maxDist = maxDist + 2 else maxDist = ISD.Radius end
        local dist = (tP - aD.wp).Magnitude
        if dist < minDist and dist <= maxDist then
            minDist = dist
            nearest = aD
        end
    end
    return nearest
end

local function startIS()
    if ISD.Connection then return end
    initScan()
    ISD.Connection = RunService.Heartbeat:Connect(function()
        if not Enabled.InstaSteal then return end
        local h = getHRP()
        if not h then return end

        pcall(function()
            local searchR = Values.StealRadius + 5
            local region = Region3.new(h.Position - Vector3.new(searchR, 20, searchR), h.Position + Vector3.new(searchR, 20, searchR))
            local parts = workspace:FindPartsInRegion3(region, Player.Character, 100)
            for _, part in ipairs(parts) do
                for _, child in ipairs(part:GetDescendants()) do
                    if child:IsA("ProximityPrompt") then
                        pcall(function()
                            child.HoldDuration = 0
                            child.RequiresLineOfSight = false
                            child.Exclusivity = Enum.Exclusivity.None
                        end)
                    end
                end
            end
        end)

        local t = findNearest(h.Position)
        if not t then return end
        local p = PMC[t.uid]
        if not p or not p.Parent then p = findPrompt(t) end

        if p and p.Enabled then
            pcall(function()
                p.HoldDuration = 0
                p.RequiresLineOfSight = false
                p.Exclusivity = Enum.Exclusivity.None
            end)
            local ok, conns = pcall(function() return getconnections(p.Triggered) end)
            if ok and type(conns) == "table" then
                for _, conn in ipairs(conns) do
                    if type(conn.Function) == "function" then pcall(conn.Function) end
                end
            end
        end
    end)
end

local function stopIS()
    -- FIX #2: ISD.Conn -> ISD.Connection (wrong variable name)
    if ISD.Connection then ISD.Connection:Disconnect(); ISD.Connection = nil end
    ISD.Scanning = false
    aAC = {}
    PMC = {}
end

-- ===== LOCK (DISTANCE 2) =====
local function findNearestP(mH)
    local nearest, nearestDist = nil, math.huge
    for _, p in Players:GetPlayers() do
        if p ~= Player and p.Character then
            local e = p.Character:FindFirstChild("HumanoidRootPart")
            local h = p.Character:FindFirstChildOfClass("Humanoid")
            if e and h and h.Health > 0 then
                local d = (e.Position - mH.Position).Magnitude
                if d < nearestDist then
                    nearestDist = d; nearest = e
                end
            end
        end
    end
    return nearest
end

local function startLock()
    local c = Player.Character
    if not c then return end
    local h = c:FindFirstChild("HumanoidRootPart")
    if not h then return end
    if lockBAV then lockBAV:Destroy() end
    lockBAV = Instance.new("BodyAngularVelocity")
    lockBAV.Name = "LockBAV"
    lockBAV.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    lockBAV.AngularVelocity = Vector3.zero
    lockBAV.Parent = h
    tag(lockBAV)
    if Connections.lock then Connections.lock:Disconnect(); Connections.lock = nil end
    Connections.lock = RunService.Heartbeat:Connect(function()
        if not Enabled.Lock or CurrentMode ~= "Lock" then return end
        pcall(function()
            local c = Player.Character
            if not c then return end
            local h = c:FindFirstChild("HumanoidRootPart")
            if not h or not lockBAV or not lockBAV.Parent then return end
            local t = findNearestP(h)
            if not t then lockBAV.AngularVelocity = Vector3.zero; return end
            local toT = t.Position - h.Position
            local flat = Vector3.new(toT.X, 0, toT.Z)
            local dist = flat.Magnitude
            local dir = dist > 0.001 and flat.Unit or Vector3.zero
            local move = Vector3.zero
            if dist > 2.1 then
                move = dir * Values.LockSpeed
            elseif dist < 1.9 then
                move = -dir * Values.LockSpeed
            end
            local yE = t.Position.Y - h.Position.Y
            local yV = math.abs(yE) > 0.1 and math.clamp(yE, -1, 1) * 40 or 0
            local look = h.CFrame.LookVector
            local tD = dist > 0.001 and flat.Unit or look
            local dot = look:Dot(tD)
            if dot < 0.995 then
                local cross = look:Cross(tD)
                local mag = cross.Magnitude
                if mag > 0.001 then lockBAV.AngularVelocity = (cross / mag) * math.clamp(dist * 0.3, 8, 25) end
            else
                lockBAV.AngularVelocity = Vector3.zero
            end
            h.AssemblyLinearVelocity = Vector3.new(move.X, yV, move.Z)
        end)
    end)
end

local function stopLock()
    if Connections.lock then Connections.lock:Disconnect(); Connections.lock = nil end
    if lockBAV then lockBAV:Destroy(); lockBAV = nil end
    pcall(function()
        local c = Player.Character
        if c then
            local h = c:FindFirstChild("HumanoidRootPart")
            if h then
                for _, v in pairs(h:GetChildren()) do if v.Name == "LockBAV" then v:Destroy() end end
            end
        end
    end)
    if CurrentMode == "Lock" then CurrentMode = "None" end
    resetVel()
end

