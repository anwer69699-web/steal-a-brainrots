-- [9] GLOW TEXT â€” animated gradient on TextLabel/Button
-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
local function glowText(lbl, speed, rA, rB, rC)
    speed = speed or SS.TextEffect
    rA = rA or C.gradA; rB = rB or C.gradB; rC = rC or C.gradC

    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,    rA),
        ColorSequenceKeypoint.new(0.45, rB),
        ColorSequenceKeypoint.new(1,    rC),
    })
    g.Rotation = 0
    g.Parent   = lbl

    task.spawn(function()
        while lbl and lbl.Parent do
            g.Rotation = (g.Rotation + speed) % 360
            task.wait(0.016)
        end
    end)
    return g
end

