    end

    -- LOCK TARGET
    local function fNP(mHRP)
        local n = nil
        local nd = math.huge
        for _, p in Players:GetPlayers() do
            if p ~= Player and p.Character then
                local eh = p.Character:FindFirstChild("HumanoidRootPart")
                local hm = p.Character:FindFirstChildOfClass("Humanoid")
                if eh and hm and hm.Health > 0 then
                    local d = (eh.Position - mHRP.Position).Magnitude
                    if d < nd then nd = d; n = eh end
                end
            end
        end
        return n, nd
    end

    local function startL()
        local c = Player.Character
        if not c then return end
        local h = c:FindFirstChild("HumanoidRootPart")
        if not h then return end
        if lockBAV then lockBAV:Destroy(); lockBAV = nil end
        lockBAV = Instance.new("BodyAngularVelocity")
        lockBAV.Name = "LockBAV"
        lockBAV.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        lockBAV.AngularVelocity = Vector3.zero
        lockBAV.Parent = h
        tag(lockBAV)
        if Connections.lock then return end
        Connections.lock = RunService.Heartbeat:Connect(function()
            if not Enabled.Lock or CurrentMode ~= "Lock" then return end
            pcall(function()
                local c = Player.Character
                if not c then return end
                local h = c:FindFirstChild("HumanoidRootPart")
                if not h then return end
                if not lockBAV or not lockBAV.Parent then return end
                local tg = fNP(h)
                if not tg then lockBAV.AngularVelocity = Vector3.zero; return end
                local tt = tg.Position - h.Position
                local flat = Vector3.new(tt.X, 0, tt.Z)
                local dist = flat.Magnitude
                local dd = 4
                local dir = dist > 0.001 and flat.Unit or Vector3.zero
                local mv = Vector3.zero
                if dist > dd + 0.1 then
                    mv = dir * Values.LockSpeed
                elseif dist < dd - 0.1 then
                    mv = -dir * Values.LockSpeed
                end
                local ye = tg.Position.Y - h.Position.Y
                local yv = 0
                if math.abs(ye) > 0.1 then yv = math.clamp(ye, -1, 1) * 40 end
                local look = h.CFrame.LookVector
                local td = dist > 0.001 and flat.Unit or look
                local dot = look:Dot(td)
                if dot < 0.995 then
                    local cr = look:Cross(td)
                    local mg = cr.Magnitude
                    if mg > 0.001 then
                        local ts = math.clamp(dist * 0.3, 8, 25)
                        lockBAV.AngularVelocity = (cr / mg) * ts
                    end
                else
                    lockBAV.AngularVelocity = Vector3.zero
                end
                h.AssemblyLinearVelocity = Vector3.new(mv.X, yv, mv.Z)
            end)
        end)
    end

    local function stopL()
        if Connections.lock then Connections.lock:Disconnect(); Connections.lock = nil end
        if lockBAV then lockBAV:Destroy(); lockBAV = nil end
        local c = Player.Character
        if c then
            local h = c:FindFirstChild("HumanoidRootPart")
            if h then
                for _, v in pairs(h:GetChildren()) do
                    if v.Name == "LockBAV" then v:Destroy() end
                end
            end
        end
        if CurrentMode == "Lock" then CurrentMode = "None" end
        resetVel()
    end

