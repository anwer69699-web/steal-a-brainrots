    local ok, res = pcall(function() return game:HttpGet(KC.KeysURL) end)
    if not ok or not res or res == "" then return {} end
    local t = {}
    for line in res:gmatch("[^\r\n]+") do
        local k, u = line:match("{(.-)},{(.-)}")
        if k and u then
            t[k:upper():gsub("%s+", "")] = u:gsub("%s+", "")
        end
    end
    return t
end

