local function verifyKey(raw)
    raw = raw and raw:upper():match("^%s*(.-)%s*$") or ""
    if #raw == 0 then return false, "Key is empty!", "error" end
    if raw == KC.OwnerKey:upper() then KS.owner = true; KS.valid = true; return true, "Owner Activated!", "owner" end
    if KC.FreeOn and raw == KC.FreeKey:upper() then KS.free = true; KS.valid = true; return true, "Free Key Activated!", "free" end
    return false, "Invalid Key!", "error"
end

