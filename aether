-- Key System
local KeySystem = { IsValid = false, IsOwner = false, IsFree = false, Config = KeySystemConfig }
function KeySystem:VerifyKey(inputKey)
    inputKey = inputKey and string.upper(string.match(inputKey, "^%s*(.-)%s*$")) or ""
    if #inputKey == 0 then return false, "Empty key!", "normal" end
    if #inputKey > self.Config.MaxKeyLength then return false, "Max 24 chars!", "normal" end
    if inputKey == string.upper(self.Config.OwnerKey) then self.IsOwner = true; self.IsValid = true; return true, "Owner activated!", "owner" end
    if self.Config.FreeKeyEnabled and inputKey == string.upper(self.Config.FreeKey) then self.IsValid = true; self.IsFree = true; return true, "Free key used!", "free" end
    return false, "Invalid key!", "normal"
end

