        elseif mode == "AutoLeft" then
            alId = alId + 1
            if alThread then pcall(function() task.cancel(alThread) end); alThread = nil end
            En.AutoLeft = false
            if VSets.AutoLeft then VSets.AutoLeft(false, true) end
        elseif mode == "AutoRight" then
            arId = arId + 1
            if arThread then pcall(function() task.cancel(arThread) end); arThread = nil end
            En.AutoRight = false
            if VSets.AutoRight then VSets.AutoRight(false, true) end
