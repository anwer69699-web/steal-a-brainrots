    local function runWP(wps, getID, setID, setThread, enKey)
        setID(getID() + 1)
        local myId = getID()
        local t = task.spawn(function()
            for _, wpd in ipairs(wps) do
                if myId ~= getID() then break end
                local wp, mode = wpd[1], wpd[2]
                while myId == getID() do
                    local ch  = Player.Character; if not ch then break end
                    local h   = ch:FindFirstChild("HumanoidRootPart"); if not h then break end
                    local dXZ = Vector3.new(wp.X - h.Position.X, 0, wp.Z - h.Position.Z)
                    if dXZ.Magnitude < 0.5 then
                        h.CFrame = CFrame.new(wp.X, h.Position.Y, wp.Z); break
                    end
                    local md = dXZ.Unit
                    local hm = ch:FindFirstChildOfClass("Humanoid")
                    if hm then hm:Move(md, false) end
                    local sp = mode == 1 and V.BoostSpeed or V.StealSpeed
                    h.AssemblyLinearVelocity =
                        Vector3.new(md.X * sp, h.AssemblyLinearVelocity.Y, md.Z * sp)
                    task.wait()
                end
                if myId ~= getID() then break end
            end
            if myId == getID() then
                resetVel(); CMode = "None"; En[enKey] = false
                if VSets[enKey] then VSets[enKey](false, true) end
            end
        end)
        setThread(t)
    end
