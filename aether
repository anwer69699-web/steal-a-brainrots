    -- HELPERS
    local function getMoveDir()
        local c = Player.Character
        if not c then return Vector3.zero end
        local h = c:FindFirstChildOfClass("Humanoid")
        return h and h.MoveDirection or Vector3.zero
    end

    local function resetVel()
        pcall(function()
            local c = Player.Character
            if not c then return end
            local h = c:FindFirstChild("HumanoidRootPart")
            local hum = c:FindFirstChildOfClass("Humanoid")
            if h then h.AssemblyLinearVelocity = Vector3.new(0, h.AssemblyLinearVelocity.Y, 0) end
            if hum then hum:Move(Vector3.zero, false) end
        end)
    end

    local function stopOldMovement(mode)
        if mode == "Lock" then
            if Connections.lock then Connections.lock:Disconnect(); Connections.lock = nil end
            if lockBAV then lockBAV:Destroy(); lockBAV = nil end
            Enabled.Lock = false
            if VisualSetters.Lock then VisualSetters.Lock(false, true) end
        elseif mode == "AutoLeft" then
            autoLeftId = autoLeftId + 1
            if autoLeftThread then pcall(function() task.cancel(autoLeftThread) end); autoLeftThread = nil end
            Enabled.AutoLeft = false
            if VisualSetters.AutoLeft then VisualSetters.AutoLeft(false, true) end
        elseif mode == "AutoRight" then
            autoRightId = autoRightId + 1
            if autoRightThread then pcall(function() task.cancel(autoRightThread) end); autoRightThread = nil end
            Enabled.AutoRight = false
            if VisualSetters.AutoRight then VisualSetters.AutoRight(false, true) end
        end
    end

    local function forceStopMovement()
        stopOldMovement(CurrentMode)
        CurrentMode = "None"
        resetVel()
    end

    local function setMovementState(ns, sf)
        if CurrentMode == ns then return end
        if CurrentMode ~= "None" then stopOldMovement(CurrentMode) end
        CurrentMode = "None"
        resetVel()
        if ns == "None" then return end
        CurrentMode = ns
        sf()
    end

    -- ANTI RAGDOLL
    local function startAntiRagdoll()
        if #AntiRagdollConns > 0 then return end
        pcall(function()
            local char = Player.Character or Player.CharacterAdded:Wait()
            local humanoid = char:WaitForChild("Humanoid")
            local root = char:WaitForChild("HumanoidRootPart")
            local cam = workspace.CurrentCamera
            local animator = humanoid:WaitForChild("Animator")
            local lastVel = Vector3.new(0, 0, 0)

            local function isRag()
                local s = humanoid:GetState()
                return s == Enum.HumanoidStateType.Physics
                    or s == Enum.HumanoidStateType.Ragdoll
                    or s == Enum.HumanoidStateType.FallingDown
                    or s == Enum.HumanoidStateType.GettingUp
            end

            local function cleanRag()
                for _, o in pairs(char:GetDescendants()) do
                    if o:IsA("BallSocketConstraint") or o:IsA("NoCollisionConstraint") or o:IsA("HingeConstraint")
                        or (o:IsA("Attachment") and (o.Name == "A" or o.Name == "B")) then
                        o:Destroy()
                    elseif o:IsA("BodyVelocity") or o:IsA("BodyPosition") or o:IsA("BodyGyro") then
                        o:Destroy()
                    elseif o:IsA("Motor6D") then
                        o.Enabled = true
                    end
                end
                for _, t in pairs(animator:GetPlayingAnimationTracks()) do
                    local n = t.Animation and t.Animation.Name:lower() or ""
                    if string.find(n, "rag") or string.find(n, "fall") or string.find(n, "hurt") or string.find(n, "down") then
                        t:Stop(0)
                    end
                end
            end

            local function reEnable()
                pcall(function()
                    require(Player:WaitForChild("PlayerScripts"):WaitForChild("PlayerModule")):GetControls():Enable()
                end)
            end

            table.insert(AntiRagdollConns, humanoid.StateChanged:Connect(function(_, ns)
                if isRag() then
                    humanoid:ChangeState(Enum.HumanoidStateType.Running)
                    cleanRag()
                    cam.CameraSubject = humanoid
                    reEnable()
                end
            end))

            table.insert(AntiRagdollConns, RunService.Heartbeat:Connect(function()
                if isRag() then
                    cleanRag()
                    local vel = root.AssemblyLinearVelocity
                    local vc = (vel - lastVel).Magnitude
                    if vc > 40 and vel.Magnitude > 25 then
                        root.AssemblyLinearVelocity = vel.Unit * math.min(vel.Magnitude, 15)
                    end
                    lastVel = vel
                end
            end))

            table.insert(AntiRagdollConns, char.DescendantAdded:Connect(function()
                if isRag() then cleanRag() end
            end))

            table.insert(AntiRagdollConns, Player.CharacterAdded:Connect(function(nc)
                char = nc
                humanoid = nc:WaitForChild("Humanoid")
                root = nc:WaitForChild("HumanoidRootPart")
                animator = humanoid:WaitForChild("Animator")
                lastVel = Vector3.new(0, 0, 0)
                reEnable()
                cleanRag()
            end))

            reEnable()
            cleanRag()
        end)
    end

    local function stopAntiRagdoll()
        for _, c in pairs(AntiRagdollConns) do pcall(function() c:Disconnect() end) end
        AntiRagdollConns = {}
    end

