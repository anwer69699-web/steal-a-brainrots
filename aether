        Conn.speed = RunService.Heartbeat:Connect(function()
            if not En.SpeedBoost or CMode ~= "None" then return end
            pcall(function()
                local hrp = getHRP(); if not hrp then return end
                local md  = getMoveDir()
                if md.Magnitude > 0.1 then
                    local sp = Player:GetAttribute("Stealing") and V.StealSpeed or V.BoostSpeed
                    hrp.AssemblyLinearVelocity =
                        Vector3.new(md.X * sp, hrp.AssemblyLinearVelocity.Y, md.Z * sp)
                end
            end)
        end)
    end
