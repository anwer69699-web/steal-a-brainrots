local function createGlowGradient(parent, speed, thickness)
    speed = speed or SpeedSettings.RowBorder
    thickness = thickness or 1.5

    local stroke = Instance.new("UIStroke")
    stroke.Thickness = thickness
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Color = Color3.new(1, 1, 1)
    stroke.Transparency = 0
    stroke.Parent = parent

    local grad = Instance.new("UIGradient")
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(20, 20, 35)),
        ColorSequenceKeypoint.new(0.4, Color3.fromRGB(70, 70, 110)),
        ColorSequenceKeypoint.new(0.7, Color3.fromRGB(140, 140, 180)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255))
    })
    grad.Rotation = 0
    grad.Parent = stroke

    task.spawn(function()
        while parent and parent.Parent do
            grad.Rotation = (grad.Rotation + speed) % 360
            local t = tick()
            local pulse = (math.sin(t * 2) + 1) / 2
            local wave = (math.sin(t * 1.5 + 1) + 1) / 2
            stroke.Transparency = 0.1 + pulse * 0.2
            stroke.Thickness = thickness + wave * 0.8
            local brightness = 220 + math.sin(t * 3) * 35
            stroke.Color = Color3.fromRGB(
                math.clamp(math.floor(brightness), 0, 255),
                math.clamp(math.floor(brightness), 0, 255),
                255
            )
            task.wait(0.033)
        end
    end)
    return stroke, grad
end

local function createTextGradient(textLabel, speed)
    speed = speed or SpeedSettings.TextEffect
    local grad = Instance.new("UIGradient")
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(20, 20, 35)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(100, 100, 150)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255))
    })
    grad.Rotation = 0
    grad.Parent = textLabel
    task.spawn(function()
        while textLabel and textLabel.Parent do
            grad.Rotation = (grad.Rotation + speed) % 360
            task.wait(0.016)
        end
    end)
    return grad
end

