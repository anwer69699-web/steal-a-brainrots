        row.ZIndex             = 20
        mkCorner(row, 7)

        local nameLbl = Instance.new("TextLabel", row)
        nameLbl.Size               = UDim2.new(0.50, 0, 1, 0)
        nameLbl.Position           = UDim2.new(0, 6, 0, 0)
        nameLbl.BackgroundTransparency = 1
        nameLbl.Text               = label
        nameLbl.TextColor3         = C.textDim
        nameLbl.Font               = Enum.Font.GothamBold
        nameLbl.TextSize           = 10
        nameLbl.TextXAlignment     = Enum.TextXAlignment.Left
        nameLbl.ZIndex             = 21

        local valLbl = Instance.new("TextLabel", row)
        valLbl.Size               = UDim2.new(0.16, 0, 1, 0)
        valLbl.Position           = UDim2.new(0.50, 0, 0, 0)
        valLbl.BackgroundTransparency = 1
        valLbl.Text               = tostring(V[valKey] or 0)
        valLbl.TextColor3         = C.text
        valLbl.Font               = Enum.Font.GothamBold
        valLbl.TextSize           = 10
        valLbl.TextXAlignment     = Enum.TextXAlignment.Right
        valLbl.ZIndex             = 21

        local track = Instance.new("Frame", row)
        track.Size             = UDim2.new(0.28, 0, 0, 7)
        track.Position         = UDim2.new(0.68, 0, 0.5, -3)
        track.BackgroundColor3 = Color3.fromRGB(18, 28, 48)
        track.BorderSizePixel  = 0
        track.ZIndex           = 21
        mkCorner(track, 5)
        glowBorder(track, SS.SliderTrack, 0.8)

        local fill = Instance.new("Frame", track)
        fill.BackgroundColor3 = C.accent
        fill.BorderSizePixel  = 0
        fill.ZIndex           = 22
        mkCorner(fill, 5)

        local pct = math.clamp(((V[valKey] or 0) - minV) / (maxV - minV), 0, 1)
        fill.Size = UDim2.new(pct, 0, 1, 0)

        local function setVal(val)
            val = math.clamp(math.floor(val), minV, maxV)
            V[valKey]   = val
            valLbl.Text = tostring(val)
            pct         = (val - minV) / (maxV - minV)
            tween(fill, {Size = UDim2.new(pct, 0, 1, 0)}, 0.07):Play()
            if onChange then onChange(val) end
        end
        SSets[valKey] = setVal

        local dragging   = false
        local sliderInp  = nil

        track.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.Touch
            or inp.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                if inp.UserInputType == Enum.UserInputType.Touch then sliderInp = inp end
            end
        end)

        RunService.RenderStepped:Connect(function()
            if not dragging then return end
            local relX
            if IS_PC then
                if not UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
                    dragging = false; return
                end
                local mp = UserInputService:GetMouseLocation()
                relX = (mp.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
            else
                if not sliderInp then dragging = false; return end
                local st = sliderInp.UserInputState
                if st == Enum.UserInputState.End or st == Enum.UserInputState.Cancel then
                    dragging = false; sliderInp = nil; return
                end
                relX = (sliderInp.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
            end
            setVal(minV + (maxV - minV) * math.clamp(relX, 0, 1))
        end)

        return row
    end

