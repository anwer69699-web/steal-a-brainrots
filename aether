    local function startFly()
        if flyActive then return end; flyActive = true
        pcall(function()
            local ch  = Player.Character; if not ch then flyActive = false; return end
            local hrp = ch:FindFirstChild("HumanoidRootPart"); if not hrp then flyActive = false; return end
            local hm  = ch:FindFirstChildOfClass("Humanoid"); if not hm  then flyActive = false; return end
            hm.PlatformStand = true

            flyBodyPos           = Instance.new("BodyPosition")
            flyBodyPos.MaxForce  = Vector3.new(1e5, 1e5, 1e5)
            flyBodyPos.Position  = hrp.Position
            flyBodyPos.D         = 200; flyBodyPos.P = 5000
            flyBodyPos.Parent    = hrp; tag(flyBodyPos)

            flyBodyGyro          = Instance.new("BodyGyro")
            flyBodyGyro.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
            flyBodyGyro.D        = 300; flyBodyGyro.P = 10000
            flyBodyGyro.CFrame   = hrp.CFrame
            flyBodyGyro.Parent   = hrp; tag(flyBodyGyro)

            Conn.fly = RunService.RenderStepped:Connect(function()
                if not flyActive then return end
                pcall(function()
                    local camCF = Camera.CFrame
                    local fwd   = camCF.LookVector
                    local rght  = camCF.RightVector
                    local up    = Vector3.new(0, 1, 0)
                    local vel   = Vector3.zero

                    if UserInputService:IsKeyDown(Enum.KeyCode.W) then vel = vel + fwd end
                    if UserInputService:IsKeyDown(Enum.KeyCode.S) then vel = vel - fwd end
                    if UserInputService:IsKeyDown(Enum.KeyCode.A) then vel = vel - rght end
                    if UserInputService:IsKeyDown(Enum.KeyCode.D) then vel = vel + rght end
                    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then vel = vel + up end
                    if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then vel = vel - up end

                    if vel.Magnitude > 0.01 then
                        flyBodyPos.Position = flyBodyPos.Position + vel.Unit * V.FlySpeed * 0.016
                    end
                    flyBodyGyro.CFrame = Camera.CFrame
                end)
            end)
        end)
    end
    local function stopFly()
        flyActive = false
        if Conn.fly then Conn.fly:Disconnect(); Conn.fly = nil end
        if flyBodyPos  then flyBodyPos:Destroy();  flyBodyPos  = nil end
        if flyBodyGyro then flyBodyGyro:Destroy(); flyBodyGyro = nil end
        pcall(function()
            local hm = getHum(); if hm then hm.PlatformStand = false end
        end)
    end

