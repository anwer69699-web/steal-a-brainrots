local function glowBorder(parent, speed, thick, colA, colB)
    speed = speed or 1; thick = thick or 1.4; colA = colA or C.accent; colB = colB or C.neon
    local stroke = Instance.new("UIStroke"); stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border; stroke.Thickness = thick; stroke.Parent = parent
