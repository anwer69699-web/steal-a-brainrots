function startMainScript(scriptVersion)
    pcall(function() Lighting.Ambient = Color3.fromRGB(127,127,127); Lighting.Brightness = 2; Lighting.ClockTime = 14; Lighting.FogEnd = 100000 end)
    
    local Values = {BoostSpeed = 58, StealSpeed = 29, LockSpeed = 54, HopPower = 23, StealRadius = 9}
    local Enabled = {SpeedBoost = false, AntiRagdoll = false, FastSteal = false, Lock = false, AutoLeft = false, AutoRight = false, Galaxy = false, GalaxySky = false}
    local CurrentMode = "None"
    local Connections = {}; local VisualSetters = {}; local SliderSetters = {}
    
    -- FIX #3: Thread IDs to properly cancel tasks without random errors
    local taskIds = { alId = 0, arId = 0 }
    
    local function resetVel() pcall(function() local c = Player.Character; if not c then return end; local h = c:FindFirstChild("HumanoidRootPart"); local hum = c:FindFirstChildOfClass("Humanoid"); if h then h.AssemblyLinearVelocity = Vector3.new(0, h.AssemblyLinearVelocity.Y, 0) end; if hum then hum:Move(Vector3.zero, false) end end) end
    
    local function stopOldMovement(mode)
        if mode == "Lock" then 
            if Connections.lock then Connections.lock:Disconnect(); Connections.lock = nil end
            -- FIX #2: Safely destroy physics objects without errors
            pcall(function() 
                local h = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
                if h then 
                    for _, v in pairs(h:GetChildren()) do 
                        if v.Name == "AetherLockBAV" then v:Destroy() end
                    end 
                end 
            end)
            Enabled.Lock = false; if VisualSetters.Lock then VisualSetters.Lock(false, true) end
        elseif mode == "AutoLeft" then 
            taskIds.alId = taskIds.alId + 1 -- Invalidate old thread
            Enabled.AutoLeft = false; if VisualSetters.AutoLeft then VisualSetters.AutoLeft(false, true) end
        elseif mode == "AutoRight" then 
            taskIds.arId = taskIds.arId + 1 -- Invalidate old thread
            Enabled.AutoRight = false; if VisualSetters.AutoRight then VisualSetters.AutoRight(false, true) end
        end
    end
    
    local function setMovementState(ns, sf) 
        if CurrentMode == ns then return end
        if CurrentMode ~= "None" then stopOldMovement(CurrentMode) end
        CurrentMode = "None"; resetVel()
        if ns == "None" then return end
        CurrentMode = ns; sf() 
    end

    -- Anti Ragdoll
    local function startAntiRagdoll()
        if Connections.antiRag then return end
        pcall(function()
            local char = Player.Character or Player.CharacterAdded:Wait()
            local humanoid = char:WaitForChild("Humanoid")
            local function isRag() local s = humanoid:GetState(); return s == Enum.HumanoidStateType.Physics or s == Enum.HumanoidStateType.Ragdoll or s == Enum.HumanoidStateType.FallingDown end
            local function cleanRag() for _, o in pairs(char:GetDescendants()) do if o:IsA("BallSocketConstraint") or o:IsA("BodyVelocity") then o:Destroy() elseif o:IsA("Motor6D") then o.Enabled = true end end end
            Connections.antiRag = humanoid.StateChanged:Connect(function() if isRag() then humanoid:ChangeState(Enum.HumanoidStateType.Running); cleanRag() end end)
            Player.CharacterAdded:Connect(function() task.wait(0.5); if Enabled.AntiRagdoll then Connections.antiRag = nil; startAntiRagdoll() end end)
        end)
    end
