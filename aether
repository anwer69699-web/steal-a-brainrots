function startMainScript(scriptVersion)
    print("[Aether] Starting v:" .. scriptVersion)

    -- [SOUND CLEANUP & DEEP CLEANING]
    local function removeCharSoundsFull(char)
        if not char then return end
        pcall(function()
            for _, obj in pairs(char:GetDescendants()) do
                if obj:IsA("Sound") then
                    obj.SoundId = ""
                    obj.Volume = 0
                    obj:Destroy()
                elseif obj:IsA("SoundEffect") or obj:IsA("ReverbSoundEffect") or obj:IsA("DistortionSoundEffect") then
                    obj:Destroy()
                end
            end
        end)
        pcall(function()
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                for _, obj in pairs(hum:GetChildren()) do
                    if obj:IsA("Sound") or obj:IsA("SoundEffect") then
                        obj:Destroy()
                    end
                end
            end
        end)
    end

    do
        local function deepClean(p, t)
            if not p then return end
            pcall(function()
                local r = {}
                for _, c in ipairs(p:GetChildren()) do
                    if c:GetAttribute(t) then
                        table.insert(r, c)
                    end
                end
                for _, c in ipairs(r) do
                    pcall(function() c:Destroy() end)
                end
            end)
        end
        deepClean(Player.PlayerGui, "AETHER_V3")
        deepClean(workspace, "AETHER_V3")
        deepClean(Lighting, "AETHER_V3")
        for _, n in ipairs({"Aether Hub V3", "Aether Hub V2", "AetherV3_ESP"}) do
            pcall(function()
                local g = Player.PlayerGui:FindFirstChild(n)
                if g then g:Destroy() end
            end)
            pcall(function()
                local f = workspace:FindFirstChild(n)
                if f then f:Destroy() end
            end)
        end
        if Player.Character then removeCharSoundsFull(Player.Character) end
        pcall(function()
            Lighting.Ambient = Color3.fromRGB(127, 127, 127)
            Lighting.Brightness = 2
            Lighting.ClockTime = 14
            Lighting.FogEnd = 100000
            for _, c in ipairs(Lighting:GetChildren()) do
                if c:GetAttribute("AETHER_V3") then c:Destroy() end
            end
        end)
        task.wait(0.5)
    end

    do
        if Player.Character then removeCharSoundsFull(Player.Character) end
        Player.CharacterAdded:Connect(function(c)
            task.wait(0.5)
            removeCharSoundsFull(c)
        end)
    end

    -- CONFIG
    local Values = {BoostSpeed = 58, StealSpeed = 29, LockSpeed = 54, GalaxyGravity = 40, HopPower = 23, StealRadius = 9}
    local Keybinds = {AutoLeft = "Q", AutoRight = "R", Lock = "V", TPDown = "T", Drop = "G"}

    local function SaveConfig()
        local d = {}
        for k, v in pairs(Values) do d[k] = v end
        d.Keybinds = {}
        for k, v in pairs(Keybinds) do d.Keybinds[k] = v end
        if writefile then
            pcall(function()
                writefile("aether_v3_config.json", HttpService:JSONEncode(d))
            end)
        end
    end

    local function LoadConfig()
        if not (readfile and isfile and isfile("aether_v3_config.json")) then return end
        local ok, data = pcall(function()
            return HttpService:JSONDecode(readfile("aether_v3_config.json"))
        end)
        if not ok or not data then return end
        for k, v in pairs(data) do
            if k == "Keybinds" and type(v) == "table" then
                for bk, bv in pairs(v) do
                    if Keybinds[bk] and type(bv) == "string" and Enum.KeyCode[bv] then
                        Keybinds[bk] = bv
                    end
                end
            elseif Values[k] ~= nil and type(v) == type(Values[k]) then
                Values[k] = v
            end
        end
    end
    LoadConfig()

    local Enabled = {SpeedBoost = false, AntiRagdoll = false, InstaSteal = false, FastSteal = false, Lock = false, AutoLeft = false, AutoRight = false, Drop = false, TPDown = false, Galaxy = false, GalaxySky = false}
