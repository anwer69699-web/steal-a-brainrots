    local ISD   = {Radius = V.StealRadius, Conn = nil, Scanning = false}
    local aAC   = {}
    local PMC   = {}
    local ISC   = {}
    local ISf   = false
    local lST   = 0

    local function isMB(pn)
        local pf = workspace:FindFirstChild("Plots"); if not pf then return false end
        local p  = pf:FindFirstChild(pn);            if not p  then return false end
        local s  = p:FindFirstChild("PlotSign");      if not s  then return false end
        local y  = s:FindFirstChild("YourBase")
        return y and y:IsA("BillboardGui") and y.Enabled
    end
    local function scanPlot(pl)
        if not pl or not pl:IsA("Model") or isMB(pl.Name) then return end
        local pd = pl:FindFirstChild("AnimalPodiums"); if not pd then return end
        for _, po in ipairs(pd:GetChildren()) do
            if po:IsA("Model") and po:FindFirstChild("Base") then
                local pv; pcall(function() pv = po:GetPivot().Position end)
                if pv then
                    table.insert(aAC, {plot=pl.Name, slot=po.Name, wp=pv, uid=pl.Name.."_"..po.Name})
                end
            end
        end
    end
    local function initScan()
        if ISD.Scanning then return end; ISD.Scanning = true
        task.spawn(function()
            task.wait(2)
            local pf = workspace:FindFirstChild("Plots")
            if not pf then pcall(function() pf = workspace:WaitForChild("Plots", 10) end) end
            if not pf then ISD.Scanning = false; return end
            for _, pl in ipairs(pf:GetChildren()) do if pl:IsA("Model") then scanPlot(pl) end end
            task.spawn(function()
                while ISD.Scanning do
                    task.wait(5); aAC = {}
                    if pf and pf.Parent then
                        for _, pl in ipairs(pf:GetChildren()) do if pl:IsA("Model") then scanPlot(pl) end end
                    end
                end
            end)
        end)
    end
    local function findPrompt(ad)
        if not ad then return nil end
        local cp = PMC[ad.uid]; if cp and cp.Parent then return cp end
        local pf = workspace:FindFirstChild("Plots"); if not pf then return nil end
        local pl = pf:FindFirstChild(ad.plot);        if not pl then return nil end
        local pd = pl:FindFirstChild("AnimalPodiums"); if not pd then return nil end
        local po = pd:FindFirstChild(ad.slot);         if not po then return nil end
        local b  = po:FindFirstChild("Base");           if not b  then return nil end
        local sp = b:FindFirstChild("Spawn");           if not sp then return nil end
        local at = sp:FindFirstChild("PromptAttachment"); if not at then return nil end
        for _, p in ipairs(at:GetChildren()) do
            if p:IsA("ProximityPrompt") then PMC[ad.uid] = p; return p end
        end
    end
    local function findNearest(tp)
        local n, md = nil, math.huge
        for _, ad in ipairs(aAC) do
            if not ad.wp then continue end
            local pm = PMC[ad.uid]; if not pm or not pm.Parent then pm = findPrompt(ad) end
            if not pm or not pm.Enabled then continue end
            local mx = (pm.MaxActivationDistance or 0) + 2
            if mx < 2 then mx = ISD.Radius + 2 end
            local d = (tp - ad.wp).Magnitude
            if d < md and d <= mx then md = d; n = ad end
        end
        return n
    end
    local function cacheCallbacks(pm)
        if ISC[pm] then return end
        local d = {hold = {}, trig = {}, ready = true}
        local o1, c1 = pcall(function() return getconnections(pm.PromptButtonHoldBegan) end)
        if o1 and type(c1) == "table" then
            for _, cn in ipairs(c1) do if type(cn.Function) == "function" then table.insert(d.hold, cn.Function) end end
        end
        local o2, c2 = pcall(function() return getconnections(pm.Triggered) end)
        if o2 and type(c2) == "table" then
            for _, cn in ipairs(c2) do if type(cn.Function) == "function" then table.insert(d.trig, cn.Function) end end
        end
        if #d.hold > 0 or #d.trig > 0 then ISC[pm] = d end
    end
    local function firePrompt(pm)
        local d = ISC[pm]; if not d or not d.ready then return false end
        if tick() - lST < 0.05 then return false end
        d.ready = false; ISf = true; lST = tick()
        task.spawn(function()
            for _, fn in ipairs(d.hold) do pcall(fn) end
            for _, fn in ipairs(d.trig) do pcall(fn) end
            task.wait(0.04); d.ready = true; ISf = false
        end)
        return true
    end
    local function doSteal(pm)
        if not pm or not pm.Parent then return false end
        cacheCallbacks(pm)
        if not ISC[pm] then return false end
        return firePrompt(pm)
    end
    local function startIS()
        if ISD.Conn then return end; initScan()
        ISD.Conn = RunService.Heartbeat:Connect(function()
            if not En.InstaSteal or ISf then return end
            local hrp = getHRP(); if not hrp then return end
            local ta  = findNearest(hrp.Position); if not ta then return end
            local pm  = PMC[ta.uid]
            if not pm or not pm.Parent then pm = findPrompt(ta) end
            if pm and pm.Enabled then doSteal(pm) end
        end)
    end
    local function stopIS()
        if ISD.Conn then ISD.Conn:Disconnect(); ISD.Conn = nil end
        ISD.Scanning = false; aAC = {}; PMC = {}; ISC = {}; ISf = false
    end

    -- â”€â”€ LOCK TARGET (rotation only, no movement) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    local function findNearestPlayer(hrp)
        local best, bd = nil, math.huge
        for _, p in Players:GetPlayers() do
            if p ~= Player and p.Character then
                local eh = p.Character:FindFirstChild("HumanoidRootPart")
                local hm = p.Character:FindFirstChildOfClass("Humanoid")
                if eh and hm and hm.Health > 0 then
                    local d = (eh.Position - hrp.Position).Magnitude
                    if d < bd then bd = d; best = eh end
                end
            end
        end
        return best
    end
    local function startLock()
        local c = Player.Character; if not c then return end
        local hrp = c:FindFirstChild("HumanoidRootPart"); if not hrp then return end
        if lockBAV then lockBAV:Destroy() end
        lockBAV = Instance.new("BodyAngularVelocity")
        lockBAV.Name            = "AetherLockBAV"
        lockBAV.MaxTorque       = Vector3.new(0, math.huge, 0)
        lockBAV.AngularVelocity = Vector3.zero
        lockBAV.Parent          = hrp
        tag(lockBAV)
        if Conn.lock then return end
        Conn.lock = RunService.Heartbeat:Connect(function()
            if not En.Lock or CMode ~= "Lock" then return end
            pcall(function()
                local ch = Player.Character; if not ch then return end
                local h  = ch:FindFirstChild("HumanoidRootPart")
                if not h or not lockBAV or not lockBAV.Parent then return end
                local tg = findNearestPlayer(h)
                if not tg then lockBAV.AngularVelocity = Vector3.zero; return end

                -- Y-axis rotation ONLY â€” no movement
                local flat = Vector3.new(tg.Position.X - h.Position.X, 0, tg.Position.Z - h.Position.Z)
                local look = h.CFrame.LookVector
                if flat.Magnitude > 0.12 then
                    local td  = flat.Unit
                    local dot = math.clamp(look:Dot(td), -1, 1)
                    if dot < 0.998 then
                        local cr = look:Cross(td)
                        if cr.Magnitude > 0.001 then
                            local spd = math.clamp((1 - dot) * 16, 3, 24)
                            lockBAV.AngularVelocity = Vector3.new(0, (cr / cr.Magnitude).Y * spd, 0)
                        end
                    else
                        lockBAV.AngularVelocity = Vector3.zero
                    end
                else
                    lockBAV.AngularVelocity = Vector3.zero
                end
            end)
        end)
    end
    local function stopLock()
        if Conn.lock then Conn.lock:Disconnect(); Conn.lock = nil end
        if lockBAV   then lockBAV:Destroy(); lockBAV = nil end
        pcall(function()
            local h = getHRP(); if not h then return end
            for _, v in h:GetChildren() do
                if v.Name == "AetherLockBAV" then v:Destroy() end
            end
        end)
        if CMode == "Lock" then CMode = "None" end
    end

