-- [8] GLOW BORDER â€” animated rotating gradient stroke
-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
local function glowBorder(parent, speed, thick, colA, colB)
    speed = speed or SS.RowBorder
    thick = thick or 1.4
    colA  = colA  or Color3.fromRGB(40, 80, 160)
    colB  = colB  or Color3.fromRGB(100, 180, 255)

    local stroke = Instance.new("UIStroke")
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Thickness        = thick
    stroke.Parent           = parent

    local grad = Instance.new("UIGradient")
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,    Color3.fromRGB(8,  10, 28)),
        ColorSequenceKeypoint.new(0.3,  colA),
        ColorSequenceKeypoint.new(0.65, colB),
        ColorSequenceKeypoint.new(1,    Color3.fromRGB(215, 238, 255)),
    })
    grad.Rotation = 0
    grad.Parent   = stroke

    task.spawn(function()
        local t0 = tick()
        while parent and parent.Parent do
            local t = tick() - t0
            grad.Rotation       = (grad.Rotation + speed) % 360
            stroke.Transparency = 0.04 + (math.sin(t * 2.1)   + 1) * 0.5 * 0.16
            stroke.Thickness    = thick + (math.sin(t * 1.35) + 1) * 0.5 * 0.75
            task.wait(SS.Pulse)
        end
    end)
    return stroke
end

