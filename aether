    if not char then return false end
    if char:GetAttribute("stealing") == true then return true end
    if char:GetAttribute("Stealing") == true then return true end
    if Player:GetAttribute("stealing") == true then return true end
    if Player:GetAttribute("Stealing") == true then return true end
