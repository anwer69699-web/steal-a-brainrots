-- [10] DRAGGABLE â€” polls InputObject (NO camera bug)
-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
local function makeDraggable(frame, handle)
    local activeInput  = nil
    local startTouchPos = Vector2.zero
    local startFrmPos   = Vector2.zero

    handle.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch
        or inp.UserInputType == Enum.UserInputType.MouseButton1 then
            activeInput   = inp
            startTouchPos = Vector2.new(inp.Position.X, inp.Position.Y)
            startFrmPos   = Vector2.new(frame.Position.X.Offset, frame.Position.Y.Offset)
        end
    end)

    RunService.RenderStepped:Connect(function()
        if not activeInput then return end
        local st = activeInput.UserInputState
        if st == Enum.UserInputState.End or st == Enum.UserInputState.Cancel then
            activeInput = nil; return
        end
        local vp = Camera.ViewportSize
        local dx = activeInput.Position.X - startTouchPos.X
        local dy = activeInput.Position.Y - startTouchPos.Y
        local nx = math.clamp(startFrmPos.X + dx, 0, vp.X - frame.AbsoluteSize.X)
        local ny = math.clamp(startFrmPos.Y + dy, 0, vp.Y - frame.AbsoluteSize.Y)
        frame.Position = UDim2.new(0, nx, 0, ny)
    end)
end

