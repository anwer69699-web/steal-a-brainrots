local LWP = {
    {Vector3.new(-474.78,-7.06,91.00), 1}, {Vector3.new(-487.94,-5.09,99.13), 1},
    {Vector3.new(-475.72,-7.05,97.02), 2}, {Vector3.new(-474.42,-7.06,24.68), 2}, {Vector3.new(-486.29,-4.99,22.06), 2}
}
local RWP = {
    {Vector3.new(-474.03,-7.06,26.82), 1}, {Vector3.new(-487.79,-5.04,20.63), 1},
    {Vector3.new(-475.02,-7.07,23.55), 2}, {Vector3.new(-473.90,-7.07,100.04), 2}, {Vector3.new(-485.13,-5.09,104.42), 2}
}

local function runPath(wp, eKey, idRef)
    local nId = idRef[1] + 1; idRef[1] = nId
    autoLeftThread = task.spawn(function()
        for _, wd in ipairs(wp) do
            if idRef[1] ~= nId then break end
            local wp2, mode = wd[1], wd[2]
            while idRef[1] == nId do
                local c = Player.Character
                if not c then break end
                local h = c:FindFirstChild("HumanoidRootPart")
                if not h then break end
                local d = Vector3.new(wp2.X - h.Position.X, 0, wp2.Z - h.Position.Z)
                if d.Magnitude < 2.5 then h.CFrame = CFrame.new(wp2.X, h.Position.Y, wp2.Z); break end
                local md = d.Unit
                local hm = c:FindFirstChildOfClass("Humanoid")
                if hm then hm:Move(md, false) end
                local spd = mode == 1 and Values.BoostSpeed or Values.StealSpeed
                h.AssemblyLinearVelocity = Vector3.new(md.X * spd, h.AssemblyLinearVelocity.Y, md.Z * spd)
                task.wait()
            end
            if idRef[1] ~= nId then break end
        end
        if idRef[1] == nId then
            resetVel(); CurrentMode = "None"; Enabled[eKey] = false
            if VisualSetters[eKey] then VisualSetters[eKey](false, true) end
            if ScreenBtnRefs[eKey] then ScreenBtnRefs[eKey](false) end
        end
    end)
end

local function startAL()
    autoLeftId = autoLeftId + 1
    autoLeftThread = task.spawn(function() runPath(LWP, "AutoLeft", {autoLeftId}) end)
end

local function startAR()
    autoRightId = autoRightId + 1
    autoRightThread = task.spawn(function() runPath(RWP, "AutoRight", {autoRightId}) end)
end

-- ===== DROP =====
local function execDrop()
    if dropFiring then return end
    dropFiring = true
    local cC = RunService.Stepped:Connect(function()
        for _, p in Players:GetPlayers() do
            if p ~= Player and p.Character then
                for _, a in p.Character:GetChildren() do
                    if a:IsA("BasePart") then a.CanCollide = false end
                end
            end
        end
    end)
    table.insert(dropConns, cC)
    task.spawn(function()
        for _ = 1, 3 do
            for _ = 1, 8 do
                if not dropFiring then break end
                pcall(function()
                    local c = Player.Character
                    if not c then return end
                    local h = c:FindFirstChild("HumanoidRootPart")
                    if not h then return end
                    local v = h.AssemblyLinearVelocity
                    h.AssemblyLinearVelocity = Vector3.new(v.X * 3000, v.Y + 3000, v.Z * 3000)
                    RunService.RenderStepped:Wait()
                    if h and h.Parent then h.AssemblyLinearVelocity = v end
                end)
                task.wait(0.005)
            end
            task.wait(0.001)
        end
        task.wait(0.001)
        for _, c in ipairs(dropConns) do pcall(function() c:Disconnect() end) end
        table.clear(dropConns)
        dropFiring = false
    end)
end

local function stopDrop()
    for _, c in ipairs(dropConns) do pcall(function() c:Disconnect() end) end
    table.clear(dropConns)
    dropFiring = false
end

