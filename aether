            local function isRag() local s = humanoid:GetState(); return s == Enum.HumanoidStateType.Physics or s == Enum.HumanoidStateType.Ragdoll or s == Enum.HumanoidStateType.FallingDown end
            local function cleanRag() for _, o in pairs(char:GetDescendants()) do if o:IsA("BallSocketConstraint") or o:IsA("BodyVelocity") then o:Destroy() elseif o:IsA("Motor6D") then o.Enabled = true end end end
