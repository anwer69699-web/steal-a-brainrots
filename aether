local KC = { FreeKey = "AETHER-FREE-2024XZQMVR", FreeEnabled = true, MaxKeyLen = 32 }
local KS = { valid = false }
local function verifyKey(raw)
    raw = raw and raw:upper():match("^%s*(.-)%s*$") or ""
    if #raw == 0 then return false, "Empty!" end
    if #raw > KC.MaxKeyLen then return false, "Too long!" end
    if KC.FreeEnabled and raw == KC.FreeKey:upper() then KS.valid = true; return true, "Activated!" end
    return false, "Wrong key!"
end

